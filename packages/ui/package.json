{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./uno.config": {
      "import": "./uno.config.ts",
      "default": "./uno.config.ts"
    },
    "./preset": {
      "import": "./src/preset/index.ts",
      "default": "./src/preset/index.ts"
    },
    "./hooks/*": {
      "import": "./src/hooks/*.ts",
      "default": "./src/hooks/*.ts"
    },
    "./lib/*": {
      "import": "./src/lib/*.ts",
      "default": "./src/lib/*.ts"
    },
    "./*": {
      "import": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    }
  },
  "scripts": {
    "check": "vp check"
  },
  "dependencies": {
    "@repo/icons": "workspace:*",
    "class-variance-authority": "catalog:ui",
    "clsx": "catalog:ui",
    "radix-ui": "catalog:ui"
  },
  "devDependencies": {
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "typescript": "catalog:dev",
    "unocss": "catalog:ui",
    "vite-plus": "catalog:dev"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-dom": "catalog:"
  }
}
